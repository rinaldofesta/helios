# Helios Configuration
# Copy to helios.toml and customize.
#
# Helios is a local-first context intelligence engine for AI coding agents.
# This config controls the LLM providers used for task orchestration and
# optional features like web search and model storage.

[general]
output_dir = "."
# data_dir = "~/.helios"          # Where databases and models are stored
# streaming = false
# max_subtasks = 20

# Where downloaded GGUF models are stored
[models]
# models_dir = "~/.helios/models"

# --- LLM Provider Configuration ---
# Used by the task orchestration engine (helios run).
# The MCP server (helios serve) uses Ollama for embeddings only.
#
# Available providers:
#   ollama            — local models via Ollama (default)
#   groq              — fast cloud inference for open-weight models
#   openai_compatible — any OpenAI-compatible server (LM Studio, vLLM, LocalAI)
#   llama_cpp         — load GGUF files directly (pip install helios[local])

[orchestrator]
provider = "ollama"
model = "llama3:instruct"

[sub_agent]
provider = "ollama"
model = "llama3:instruct"

[refiner]
provider = "ollama"
model = "llama3:instruct"

[tools]
web_search_enabled = false
# tavily_api_key = ""  # or set TAVILY_API_KEY env var
read_file_enabled = true

# --- Alternative Configurations ---

# Groq (fast cloud inference for open-weight models):
# [orchestrator]
# provider = "groq"
# model = "llama-3.3-70b-versatile"
# api_key = ""  # or set GROQ_API_KEY env var

# OpenAI-compatible server (LM Studio, vLLM, etc.):
# [orchestrator]
# provider = "openai_compatible"
# model = "your-model-name"
# base_url = "http://localhost:1234/v1"

# Direct GGUF loading:
# [orchestrator]
# provider = "llama_cpp"
# model_path = "~/.helios/models/model.gguf"
# n_ctx = 8192
# n_gpu_layers = -1
